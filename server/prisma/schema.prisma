generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id            String   @id @default(cuid())
  registration  String   @unique
  name          String
  type          String
  region        String
  capacity      Float
  odometer      Float
  purchaseCost  Float
  status        VehicleStatus @default(AVAILABLE)

  trips         Trip[]
  maintenance   Maintenance[]
  fuelLogs      FuelLog[]
  expenses      Expense[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([region])
}

model Driver {
  id            String   @id @default(cuid())
  name          String
  phone         String
  licenseNumber String   @unique
  licenseCategory String
  expiryDate    DateTime
  safetyScore   Float
  status        DriverStatus @default(AVAILABLE)

  trips         Trip[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([expiryDate])
}

model Trip {
  id          String @id @default(cuid())

  vehicleId   String
  driverId    String

  source      String
  destination String

  cargoWeight Float
  distance    Float
  revenue     Float?
  finalOdometer Float?
  fuelConsumed Float?

  status      TripStatus @default(DRAFT)

  vehicle Vehicle @relation(fields:[vehicleId], references:[id])
  driver Driver @relation(fields:[driverId], references:[id])

  fuelLogs FuelLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dispatchedAt DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
}

model Maintenance {
  id          String @id @default(cuid())

  vehicleId   String

  description String

  cost        Float

  status      MaintenanceStatus

  vehicle Vehicle @relation(fields:[vehicleId], references:[id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  completedAt DateTime?

  @@index([vehicleId])
  @@index([status])
}

model FuelLog {
  id String @id @default(cuid())

  vehicleId String

  tripId String?

  liters Float

  cost Float

  mileage Float
  loggedAt DateTime @default(now())

  vehicle Vehicle @relation(fields:[vehicleId], references:[id])

  trip Trip? @relation(fields:[tripId], references:[id])

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([tripId])
  @@index([loggedAt])
}

model Expense {
  id String @id @default(cuid())

  vehicleId String

  category String

  amount Float

  notes String?
  expenseDate DateTime @default(now())

  vehicle Vehicle @relation(fields:[vehicleId], references:[id])

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([category])
  @@index([expenseDate])
}
